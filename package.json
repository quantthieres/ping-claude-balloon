{
  "name": "@quantthieres/ping-balloon",
  "version": "0.1.0",
  "description": "Ping Balloon — floating desktop notification bubble for terminal coding agents",
  "keywords": [
    "ping-balloon",
    "claude-code",
    "electron",
    "notifications",
    "desktop",
    "productivity",
    "agent"
  ],
  "author": "quantthieres",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantthieres/ping-claude-balloon.git"
  },
  "bugs": {
    "url": "https://github.com/quantthieres/ping-claude-balloon/issues"
  },
  "homepage": "https://github.com/quantthieres/ping-claude-balloon#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "electron/main.js",
  "bin": {
    "ping-balloon": "bin/agent-ping.js"
  },
  "files": [
    "bin/",
    "electron/",
    "scripts/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "dev": "concurrently -k -n vite,electron \"vite\" \"wait-on http://localhost:5173 && node scripts/electron-dev.js\"",
    "build": "vite build",
    "start": "electron .",
    "app:start": "electron .",
    "cli": "node bin/agent-ping.js",
    "doctor": "node bin/agent-ping.js doctor",
    "health": "node scripts/notify.js health",
    "notify:complete": "node scripts/notify.js complete",
    "notify:waiting": "node scripts/notify.js waiting",
    "notify:permission": "node scripts/notify.js permission",
    "hooks:install": "node scripts/install-claude-hooks.js",
    "hooks:uninstall": "node scripts/uninstall-claude-hooks.js"
  },
  "dependencies": {
    "electron": "^33.4.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "type": "commonjs"
}
